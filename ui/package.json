{
  "name": "burrow-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Burrow frontend — tiling web UI for many concurrent Claude Code terminal sessions (Vite 8 + React 19 + xterm.js + react-mosaic).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
