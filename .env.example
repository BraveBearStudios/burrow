# Burrow control plane — example environment.
# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# ── Proxmox connection ────────────────────────────────────────────────
PROXMOX_HOST=pve1.local
PROXMOX_USER=burrow@pve            # dedicated least-privilege user, NOT root@pam
PROXMOX_TOKEN_NAME=burrow
PROXMOX_TOKEN_VALUE=               # set in .env only
PROXMOX_CA_CERT_PATH=/etc/burrow/pve-ca.pem   # node CA cert; do not use verify_ssl=False

# ── Worker config distribution ────────────────────────────────────────
CONFIG_REPO=git@github.com:your-org/cc-worker-config.git
CONFIG_BRANCH=main

# ── LXC settings ──────────────────────────────────────────────────────
TEMPLATE_VMID=9000
WORKER_POOL_START=200
WORKER_POOL_END=299
DEFAULT_NODE=pve1

# ── Worker net0 / static-IP-from-VMID (ADR-0004) ──────────────────────
# Placeholders — set your real LAN topology here (this file is gitignored).
WORKER_SUBNET=10.99.0.0/24
WORKER_GATEWAY=10.99.0.1
WORKER_BRIDGE=vmbr0
WORKER_PREFIX=24

# ── Capacity guard (CAP-01) ───────────────────────────────────────────
CAPACITY_THRESHOLD=0.80           # refuse create above this node-RAM fraction

# ── Saga timeouts (seconds) ───────────────────────────────────────────
TTYD_TIMEOUT=60
TTYD_INTERVAL=2
CLONE_TIMEOUT=300                 # --full clone UPID wait (tune in homelab)
TASK_TIMEOUT=120                  # start/stop/destroy UPID wait

# ── Security headers / CORS (PLAT-05) ─────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173   # the LAN UI origin; NEVER "*"

# ── Bootconfig (WORK-03 / ADR-0002) ───────────────────────────────────
GIT_CREDENTIAL_TOKEN=             # short-lived repo-scoped token; set in .env only
BOOTCONFIG_SOURCE_IP_CHECK=false  # defense-in-depth source-IP binding (off by default)

# ── Credential store (ADR-0015) ───────────────────────────────────────
# Fernet master key for the encrypted-at-rest credential store (Proxmox token +
# GitHub PAT, managed in the GUI). Onboarding auto-generates this; to make one by
# hand: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Self-host only: keep it in .env, never in the DB or source. Without it the
# credential store stays disabled and the values above are used as-is.
BURROW_SECRET_KEY=                 # 44-char urlsafe-base64 Fernet key; set in .env only

# ── Database ──────────────────────────────────────────────────────────
DATABASE_PATH=/data/burrow.db

# ── Security (hosted/multi-tenant mode only) ──────────────────────────
# JWKS_URL=
# ALLOWED_ORIGINS=https://burrow.example.com
