# Burrow control plane — example environment.
# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# ── Proxmox connection ────────────────────────────────────────────────
PROXMOX_HOST=pve1.local
PROXMOX_USER=burrow@pve            # dedicated least-privilege user, NOT root@pam
PROXMOX_TOKEN_NAME=burrow
PROXMOX_TOKEN_VALUE=               # set in .env only
PROXMOX_CA_CERT_PATH=/etc/burrow/pve-ca.pem   # node CA cert; do not use verify_ssl=False

# ── Worker config distribution ────────────────────────────────────────
CONFIG_REPO=git@github.com:your-org/cc-worker-config.git
CONFIG_BRANCH=main

# ── LXC settings ──────────────────────────────────────────────────────
TEMPLATE_VMID=9000
WORKER_POOL_START=200
WORKER_POOL_END=299
DEFAULT_NODE=pve1

# ── Database ──────────────────────────────────────────────────────────
DATABASE_PATH=/data/burrow.db

# ── Security (hosted/multi-tenant mode only) ──────────────────────────
# JWKS_URL=
# ALLOWED_ORIGINS=https://burrow.example.com
