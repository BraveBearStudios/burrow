# burrow-ui production image (ci-cd-and-testing.md §2.1/§2.2).
#
# Multi-stage: node:22 builds the Vite SPA (npm ci from the committed lockfile →
# dist/); the nginx:1.27-alpine runtime carries ONLY the static build + an
# unprivileged nginx config. Base images are pinned by DIGEST. nginx runs as the
# non-root `nginx` user on port 8080 (a non-root process cannot bind :80), with a
# HEALTHCHECK that asserts a 200 on /.

# ── Build stage ────────────────────────────────────────────────────────
# node:22 — digest resolved 2026-06-11 (multi-arch index).
FROM node:22@sha256:2d178f2785b96dfbf62a416ca2e40f50e30150b4ff3320d706f0d96e90600eb3 AS build

WORKDIR /app

# Dependency layer first (manifest + lockfile only) for cache reuse; npm ci is a
# deterministic install from the committed package-lock.json (§2.2).
COPY ui/package.json ui/package-lock.json ./
RUN npm ci

# Then the source, and produce the static bundle (Vite → dist/).
COPY ui/ ./
RUN npm run build

# ── Runtime stage ──────────────────────────────────────────────────────
# nginx:1.27-alpine — digest resolved 2026-06-11 (multi-arch index).
FROM nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10 AS runtime

# OCI provenance + AGPL §13 source-availability labels (dynamic values from CI).
ARG IMAGE_REVISION=dev
ARG IMAGE_CREATED=unknown
ARG IMAGE_VERSION=0.1.0
LABEL org.opencontainers.image.source="https://github.com/BraveBearStudios/burrow" \
      org.opencontainers.image.revision="${IMAGE_REVISION}" \
      org.opencontainers.image.created="${IMAGE_CREATED}" \
      org.opencontainers.image.licenses="AGPL-3.0-or-later" \
      org.opencontainers.image.title="burrow-ui" \
      org.opencontainers.image.version="${IMAGE_VERSION}"

# Unprivileged nginx: serve the SPA on :8080 and write the pid + all temp paths
# under /tmp so a non-root user owns every file nginx touches at runtime.
RUN set -eux; \
    { \
      echo 'pid /tmp/nginx.pid;'; \
      echo 'worker_processes auto;'; \
      echo 'events { worker_connections 1024; }'; \
      echo 'http {'; \
      echo '  include /etc/nginx/mime.types;'; \
      echo '  default_type application/octet-stream;'; \
      echo '  client_body_temp_path /tmp/nginx-client;'; \
      echo '  proxy_temp_path /tmp/nginx-proxy;'; \
      echo '  fastcgi_temp_path /tmp/nginx-fastcgi;'; \
      echo '  uwsgi_temp_path /tmp/nginx-uwsgi;'; \
      echo '  scgi_temp_path /tmp/nginx-scgi;'; \
      echo '  sendfile on;'; \
      echo '  server {'; \
      echo '    listen 8080;'; \
      echo '    server_name _;'; \
      echo '    root /usr/share/nginx/html;'; \
      echo '    index index.html;'; \
      echo '    # SPA history fallback: any non-asset route serves index.html so'; \
      echo '    # client-side routing survives a hard refresh (UI-05).'; \
      echo '    location / { try_files $uri $uri/ /index.html; }'; \
      echo '  }'; \
      echo '}'; \
    } > /etc/nginx/nginx.conf; \
    # The static bundle and the dirs nginx writes to are owned by the non-root user.
    chown -R nginx:nginx /usr/share/nginx/html /etc/nginx/nginx.conf

# Replace the default site assets with the built SPA, owned by the runtime user.
COPY --from=build --chown=nginx:nginx /app/dist /usr/share/nginx/html

USER nginx

EXPOSE 8080

# HEALTHCHECK asserts nginx returns a 200 on / using wget (present in alpine).
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD ["wget", "--quiet", "--tries=1", "--spider", "http://localhost:8080/"]

CMD ["nginx", "-g", "daemon off;"]
